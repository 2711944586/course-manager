AURORA_ENV=development
AURORA_APP_NAME=Aurora Course Manager API
AURORA_APP_VERSION=0.1.0
AURORA_API_PREFIX=/api/v1
AURORA_DATABASE_URL=sqlite:///server/data/aurora.db
AURORA_CORS_ORIGINS=http://127.0.0.1:4200,http://localhost:4200
AURORA_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
AURORA_JWT_EXPIRE_MINUTES=120
